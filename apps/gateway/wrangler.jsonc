{
  // HMLS API + Fixo API on Cloudflare Workers (one worker, hostname dispatch in
  // worker.ts: api.fixo.* → fixoApp, else hmlsApp). Combined bundle is ~1.7 MB
  // gzip, well under the 10 MB limit, so no split. Validate with `wrangler dev`.
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "hmls-api",
  // Pre-built by `deno task build:worker` (esbuild + @deno/esbuild-plugin).
  // wrangler's own bundler can't resolve deno.json imports (JSR deps, Deno
  // workspace packages) — see docs/cloudflare-migration.md C1/C2.
  "main": "dist/worker.js",
  "no_bundle": true,
  // dist/yoga.wasm (extracted by build:worker) uploads as a pre-compiled
  // WebAssembly.Module — workerd forbids compiling wasm from bytes at runtime.
  "find_additional_modules": true,
  "rules": [{ "type": "CompiledWasm", "globs": ["**/*.wasm"] }],
  // nodejs_compat unlocks: postgres-js (TCP sockets), AsyncLocalStorage, Buffer.
  // Sept 2024+ compat date is required for the Node TCP socket support.
  "compatibility_date": "2025-07-01",
  "compatibility_flags": ["nodejs_compat"],
  "observability": { "enabled": true },
  "triggers": {
    // Daily abandoned-draft reap (was Deno.cron). 03:00 UTC.
    "crons": ["0 3 * * *"]
  },
  "vars": {
    "HMLS_AGENT_MODEL": "deepseek-v4-pro",
    "AGENT_MODEL": "gemini-3.1-flash-lite",
    "FIXO_MEDIA_BUCKET": "fixo-media",
    "LOG_LEVEL": "info"
  }
  // DB: connect directly to Supabase's TRANSACTION-mode pooler (host
  // ...pooler.supabase.com, port 6543). No Hyperdrive — the client uses
  // prepare:false, which transaction pooling requires. If cold-connection
  // latency ever becomes a measured problem, add a Hyperdrive binding and
  // point these two connection strings at it (small change, no rewrite).
  //
  // Secrets (wrangler secret put ...):
  //   DATABASE_URL          — service_role @ 6543 pooler (admin/system)
  //   TENANT_DATABASE_URL   — restricted role @ 6543 pooler (RLS-enforcing)
  //   DEEPSEEK_API_KEY, STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET,
  //   SLACK_WEBHOOK_URL, SUPABASE_URL, SUPABASE_ANON_KEY
  //   GOOGLE_API_KEY         — Fixo agent (Gemini)
  //   SUPABASE_SERVICE_ROLE_KEY — Fixo media storage
}
